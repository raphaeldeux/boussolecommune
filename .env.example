# --- LLM : choisir une source (Ollama est prioritaire) ---
# Ollama en local (recommandé pour le dev)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=mistral

# OpenRouter (optionnel, utilisé si OLLAMA_BASE_URL est absent)
# OPENROUTER_API_KEY=sk-or-v1-...

# Anthropic (optionnel, utilisé en dernier recours)
# ANTHROPIC_API_KEY=sk-ant-...

ADMIN_PASSWORD=changeme
SECRET_KEY=changeme-secret-key
FLASK_ENV=production
